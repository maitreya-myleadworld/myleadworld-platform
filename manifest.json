{
  "manifest_version": 3,
  "name": "MyLeadWorld Scraper",
  "version": "1.0.0",
  "description": "Extract LinkedIn leads directly into your MyLeadWorld dashboard.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://api.myleadworld.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*", 
        "https://www.linkedin.com/sales/lead/*"
      ],
      "js": ["content.js"]
    }
  ]
}